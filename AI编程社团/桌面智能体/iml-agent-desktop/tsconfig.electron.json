{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-electron",
    "module": "CommonJS",
    "target": "es2022",
    "moduleResolution": "node",
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false
  },
  "include": ["electron"]
}
